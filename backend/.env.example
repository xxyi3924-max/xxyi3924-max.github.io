# LLM Provider — choose one: claude | openai | gemini
LLM_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (ChatGPT)
OPENAI_API_KEY=sk-...

# Google (Gemini)
GEMINI_API_KEY=...

# Data APIs
POLYGON_API_KEY=...
TWELVE_DATA_API_KEY=...

# Reddit (no credentials needed — uses public JSON API)
REDDIT_USER_AGENT=smartmoney-agent/1.0

# X (Twitter) — Playwright + cookie injection (no login API, no lockout risk)
# Get from browser DevTools → Application → Cookies → https://x.com
# Required:
X_AUTH_TOKEN=
X_CT0=
# Optional (helps avoid login redirect):
X_GUEST_ID=

# Dev
MOCK_MODE=false
